{
  "sources": [
    "D:/data/report.pdf",
    "D:/data/photos"
  ],
  "source_passwords": {
    "D:/data/report.pdf": {
      "type": "env",
      "name": "HSE_REPORT_PASSWORD"
    },
    "D:/data/photos": {
      "type": "env",
      "name": "HSE_PHOTOS_PACKAGE_PASSWORD"
    }
  },
  "metadata_password": {
    "type": "env",
    "name": "HSE_METADATA_PASSWORD"
  },
  "output_dir": "D:/encrypted",
  "batch_id": "no-password-tables-example",
  "security_mode": "no-password-tables",
  "individually_encrypted_files_by_folder": {
    "D:/data/photos": [
      "private/secret.jpg"
    ]
  },
  "folder_inner_passwords": {
    "D:/data/photos": {
      "private/secret.jpg": {
        "type": "env",
        "name": "HSE_SECRET_JPG_PASSWORD"
      }
    }
  }
}
